# FIN1 Backend Environment Variables - Production Template
# Copy this file to .env and update ALL values for production use
# IMPORTANT: Change all passwords and secrets before deploying!

# ============================================
# Parse Server Configuration
# ============================================
PARSE_SERVER_APPLICATION_ID=fin1-app-id
PARSE_SERVER_MASTER_KEY=CHANGE-THIS-TO-STRONG-RANDOM-PASSWORD
# Mongo-URI: Auf Ubuntu/iobox setzt docker-compose.production.yml PARSE_SERVER_DATABASE_URI aus
# ${MONGO_INITDB_ROOT_PASSWORD} — kanonisch nur in ~/fin1-server/.env (nicht hier duplizieren).
# Optionaler Fallback nur für Setups ohne dieses Compose-Override:
# PARSE_SERVER_DATABASE_URI=mongodb://admin:CHANGE-THIS@mongodb:27017/fin1?authSource=admin
PARSE_SERVER_CLOUD_CODE_MAIN=./cloud/main.js

# Server URLs - Replace with your Ubuntu server IP or domain
# Recommended when using Nginx on port 80:
# Example: http://192.168.178.24/parse
# Browser-facing REST URL (nginx HTTPS). Parse uses loopback for verifyServerUrl unless overridden.
PARSE_SERVER_PUBLIC_SERVER_URL=https://YOUR-UBUNTU-IP/parse
# Optional; default http://127.0.0.1:${PORT}/parse inside the parse-server container
# PARSE_SERVER_INTERNAL_URL=http://127.0.0.1:1337/parse
PARSE_SERVER_LIVE_QUERY_SERVER_URL=wss://YOUR-UBUNTU-IP/parse
PARSE_SERVER_PRODUCTION_URL=https://YOUR-UBUNTU-IP/parse

# Optional (Parse Server 6.x): allow master key usage from specific IP ranges
# Recommended (secure): only localhost + Docker private range (dashboard via SSH tunnel)
# Example: 127.0.0.1/32,::1/128,172.16.0.0/12
PARSE_SERVER_MASTER_KEY_IPS=127.0.0.1/32,::1/128,172.16.0.0/12

# Optional: Parse Dashboard should talk to the Parse API through an SSH tunnel,
# not through the LAN. This URL is embedded into the dashboard frontend.
# Recommended: tunnel local port 1338 to server 127.0.0.1:1338
# Same URL the browser uses to reach Parse (public HTTPS), or your SSH tunnel to 127.0.0.1:1338/parse
PARSE_DASHBOARD_SERVER_URL=https://YOUR-UBUNTU-IP/parse

# ============================================
# Database Configuration
# ============================================
# MongoDB (Root): Single Source of Truth = ~/fin1-server/.env (Compose-Interpolation).
# NICHT MONGO_INITDB_ROOT_PASSWORD in backend/.env pflegen — Drift-Check: scripts/check-fin1-mongo-root-env-drift.sh

# PostgreSQL
POSTGRES_DB=fin1_analytics
POSTGRES_USER=fin1_user
POSTGRES_PASSWORD=CHANGE-THIS-TO-STRONG-PASSWORD
POSTGRES_URL=postgresql://fin1_user:${POSTGRES_PASSWORD}@postgres:5432/fin1_analytics

# Redis
REDIS_PASSWORD=CHANGE-THIS-TO-STRONG-PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ============================================
# Push Notifications
# ============================================
PARSE_SERVER_PUSH_APNS_CERT_PATH=/app/certs/apns.p12
PARSE_SERVER_PUSH_APNS_KEY_ID=your-apns-key-id
PARSE_SERVER_PUSH_APNS_TEAM_ID=your-apple-team-id
PARSE_SERVER_PUSH_APNS_BUNDLE_ID=com.fin1.app
PARSE_SERVER_PUSH_APNS_PRODUCTION=true
PARSE_SERVER_PUSH_FCM_API_KEY=your-fcm-server-key

# ============================================
# File Storage (MinIO/S3)
# ============================================
S3_BUCKET=fin1-files
S3_REGION=us-east-1
MINIO_ROOT_USER=fin1-minio-admin
MINIO_ROOT_PASSWORD=CHANGE-THIS-TO-STRONG-PASSWORD
S3_ACCESS_KEY=${MINIO_ROOT_USER}
S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}
S3_ENDPOINT=http://minio:9000

# ============================================
# Market Data API
# ============================================
MARKET_DATA_API_KEY=your-market-data-api-key
MARKET_DATA_WS_URL=wss://your-market-data-websocket-url

# ============================================
# Security - CRITICAL: Change these!
# ============================================
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE-THIS-TO-RANDOM-32-CHAR-STRING
ENCRYPTION_KEY=CHANGE-THIS-TO-32-CHAR-ENCRYPTION-KEY

# ============================================
# Dashboard Access (Production)
# ============================================
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=CHANGE-THIS-ADMIN-PASSWORD

# ============================================
# CORS Configuration
# ============================================
# Add your iOS app and any web clients
# Example: http://192.168.178.50,http://localhost:3000
ALLOWED_ORIGINS=http://YOUR-UBUNTU-IP,http://localhost:3000

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FILE=/app/logs/app.log

# ============================================
# Environment
# ============================================
# Optional: Admin-Portal DEV maintenance — FAQ hard delete / baseline reset (Cloud Function devResetFAQsBaseline).
# Keep false/unset in real production unless you intentionally need destructive cleanup.
# ALLOW_FAQ_HARD_DELETE=true
# If NODE_ENV=production and you still need this, also set:
# ALLOW_FAQ_HARD_DELETE_IN_PRODUCTION=true

NODE_ENV=production
PORT=1337

# ============================================
# Server Information (Auto-filled by deployment script)
# ============================================
SERVER_IP=YOUR-UBUNTU-IP
SERVER_HOSTNAME=YOUR-UBUNTU-HOSTNAME
