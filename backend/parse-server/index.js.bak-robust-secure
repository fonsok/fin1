  contentSecurityPolicy: false, // Disable CSP for Dashboard compatibility
}));

// CORS configuration
app.use(cors({
  origin: process.env.ALLOWED_ORIGINS?.split(',') || ['http://localhost:3000'],
  credentials: true,
}));

// Compression and logging
app.use(compression());
app.use(morgan('combined'));

