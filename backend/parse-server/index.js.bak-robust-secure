// Async startup function for Parse Server 6.x
async function startServer() {
  const port = process.env.PORT || 1337;

  // Initialize and start Parse Server (required for Parse Server 6.x)
  const parseServer = new ParseServer(parseServerConfig);
  await parseServer.start();
  console.log('✅ Parse Server initialized and connected to MongoDB');

  // Mount Parse Server AFTER start()
  app.use('/parse', parseServer.app);

  // Mount Parse Dashboard
  const dashboard = new ParseDashboard(parseDashboardConfig, { allowInsecureHTTP: true });
  app.use('/dashboard', dashboard);

  // Error handling middleware (AFTER Parse Server mount)
  app.use((err, req, res, next) => {
    console.error('Error:', err);
    res.status(500).json({
      error: 'Internal Server Error',
      message: process.env.NODE_ENV === 'development' ? err.message : 'Something went wrong',
    });
  });

  // 404 handler (MUST be last)
  app.use('*', (req, res) => {
    res.status(404).json({
      error: 'Not Found',
      message: 'The requested resource was not found',
    });
  });

  // Start HTTP server
  const httpServer = require('http').createServer(app);

  httpServer.listen(port, () => {
    console.log(`FIN1 Parse Server running on port ${port}`);
    console.log(`Dashboard available at http://localhost:${port}/dashboard`);
    console.log(`API available at http://localhost:${port}/parse`);
  });

  // Start Parse Live Query WebSocket Server
  try {
    await ParseServer.createLiveQueryServer(httpServer, {
      appId: parseServerConfig.appId,
      masterKey: parseServerConfig.masterKey,
      serverURL: parseServerConfig.serverURL,
      websocketTimeout: 10 * 1000,
      cacheTimeout: 5 * 1000,
      logLevel: process.env.LOG_LEVEL || 'INFO',
    });
    console.log('✅ Parse Live Query WebSocket Server started on port', port);
  } catch (error) {
    console.error('❌ Failed to start Parse Live Query Server:', error);
  }

  // Graceful shutdown
  process.on('SIGTERM', () => {
    console.log('SIGTERM received, shutting down gracefully');
    httpServer.close(() => {
      console.log('Process terminated');
    });
  });

  return { app, parseServer, httpServer };
}

// Start the server and export for testing
let serverInstance = null;

startServer()
  .then((instance) => {
    serverInstance = instance;
  })
  .catch((error) => {
    console.error('❌ Failed to start FIN1 Parse Server:', error);
    process.exit(1);
  });

module.exports = { app, getServer: () => serverInstance };
