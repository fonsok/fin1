// Shared base configuration for FIN1.
//
// Notes:
// - Values from here are used by Info.plist via $(...) placeholders.
// - Environment-specific overrides live in FIN1-Dev / FIN1-Staging / FIN1-Prod.

FIN1_URL_SLASH = /

// IMPORTANT: In .xcconfig files, `//` starts a comment.
// To safely build URLs, we construct `http://` via `$(FIN1_URL_SLASH)$(FIN1_URL_SLASH)`.
FIN1_PARSE_SERVER_URL = http:$(FIN1_URL_SLASH)$(FIN1_URL_SLASH)192.168.178.20$(FIN1_URL_SLASH)parse
FIN1_PARSE_APPLICATION_ID = fin1-app-id
FIN1_PDF_SERVICE_BASE_URL = http:$(FIN1_URL_SLASH)$(FIN1_URL_SLASH)192.168.178.20:8086

