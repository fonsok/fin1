# Nur für CI: Variablen, die docker-compose.production.yml per ${…} interpoliert.
# Keine echten Secrets — niemals auf Server verwenden.
MONGO_INITDB_ROOT_PASSWORD=ci-stub-mongo-root-password
REDIS_PASSWORD=ci-stub-redis-password
POSTGRES_PASSWORD=ci-stub-postgres-password
MINIO_ROOT_USER=ci-stub-minio-user
MINIO_ROOT_PASSWORD=ci-stub-minio-root-password

# Merge mit docker-compose.parse-server-ghcr.yml (nur Platzhalter für compose config -q)
FIN1_PARSE_SERVER_IMAGE=ghcr.io/ci-placeholder/fin1-parse-server:stub
