# FIN1 return% monitor settings (server-local)
# Copy to: /home/io/fin1-server/scripts/monitor.env

# Allowed missing count before script exits non-zero.
MONITOR_THRESHOLD=0

# Catch-up window for --catchup mode (seconds).
# Default: 25h = 90000
MAX_AGE_SECONDS=90000

# Optional Slack webhook for breach alerts.
# RETURN_MONITOR_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Optional email fallback alert for breach (if 'mail' or 'mailx' is installed).
# RETURN_MONITOR_ALERT_EMAIL_TO=ops@example.com
# RETURN_MONITOR_ALERT_EMAIL_FROM=fin1-monitor@example.com

# Optional: force breach for pipeline testing (no DB mutation). Set back to 0.
# RETURN_MONITOR_FORCE_BREACH=0
