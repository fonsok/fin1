# Optional: Zeilen in ~/fin1-server/.env auf iobox ergänzen (nicht committen), nachdem CI auf
# main/master nach ghcr.io/<GITHUB-OWNER-KLEIN>/fin1-parse-server gepusht hat.
#
# FIN1_PARSE_SERVER_IMAGE=ghcr.io/<GITHUB-OWNER-KLEIN>/fin1-parse-server:main
#
# Dann: docker login ghcr.io (PAT read:packages) und:
#   docker compose -f docker-compose.production.yml -f docker-compose.parse-server-ghcr.yml pull parse-server
#   docker compose -f docker-compose.production.yml -f docker-compose.parse-server-ghcr.yml up -d --no-deps parse-server
#
# Siehe Documentation/FIN1_APP_DOCS/06A_BACKEND_UBUNTU_IOBOX_RUNBOOK.md § 8.1.
