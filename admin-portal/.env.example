# FIN1 Admin Portal Environment Variables

# Parse Server Configuration (Application ID must match backend, e.g. docker-compose / Config/FIN1-Base.xcconfig)
VITE_PARSE_APP_ID=fin1-app-id
VITE_PARSE_SERVER_URL=/parse
VITE_PARSE_JS_KEY=

# For development with direct connection to backend:
# VITE_PARSE_SERVER_URL=http://localhost:1337/parse

# For production (via reverse proxy):
# VITE_PARSE_SERVER_URL=/parse
