flowchart TD
    TITLE(["<b>Page 2 – Investor</b><br/>When does an investor receive Risk Class 5?<br/>Steps 15, 16, 17"])

    subgraph S15["<b>Step 15 – Financial information</b>"]
        S15A["Dropdown <b>Employment status</b><br/>Special pathway: must <b>not</b> be „Unemployed“<br/>(Employed, Self-Employed, Student, Retired = OK)"]
        S15B["Dropdowns <b>Income</b> & <b>liquid assets</b><br/>→ 0–12 score points<br/>(higher = more points, helps Path 1)"]
        S15C["Income sources (multi-select)<br/>Assets +2, Inheritance +1, Settlement +1 points"]
    end

    subgraph S16["<b>Step 16 – Investment experience</b>"]
        S16A["a) Stocks, b) ETFs<br/>Count + amount → score points<br/>(not mandatory, but helpful for Path 1)"]
        S16B["<b>c) Certificates & derivatives – REQUIRED for RC 5</b>"]
        S16C["Investor gate (minimum):<br/>✓ Count: <b>1–10</b> (+1 pt.) or higher<br/>✓ Amount: <b>€1,000–10,000</b> (+1) or higher<br/>✓ Holding: <b>Days to weeks</b> (+1 pt.) or shorter"]
        S16D["d) Real estate (+2) / Gold (+1) → bonus points"]
    end

    subgraph S17["<b>Step 17 – Target return & risk check</b>"]
        S17A["Dropdown return:<br/>✓ <b>≥ 50%</b> (+3 pts.) or <b>≥ 100%</b> (+5 pts.)<br/>✗ <b>≥ 10%</b> → safety cap max. RC 2"]
        S17B["Total loss risk: confirm <b>Yes</b>"]
        S17C["Knowledge test: <b>all questions correct</b><br/>If No or errors → <b>final RC 1</b>"]
    end

    TITLE --> S15A
    S15A --> PATH
    S15B --> PATH
    S15C --> PATH
    S16A --> PATH
    S16B --> S16C
    S16C --> GATE
    S16D --> PATH
    S17A --> PATH
    S17B --> FINAL
    S17C --> OUT_RC1

    PATH{"<b>Path 1: Score pathway</b><br/>Total points from steps 15–17<br/><b>19–25 points</b> → RC 5 candidate"}

    PATH -->|"19–25 points"| GATE
    PATH -->|"less than 19"| SPEC

    SPEC{"<b>Path 2: Investor special pathway</b><br/>Possible even with low score<br/>if <b>all three</b> are met:<br/>1. Employment ≠ Unemployed<br/>2. Derivatives gate 16c (see above)<br/>3. Return ≥ 50%"}

    SPEC -->|all yes| GATE
    SPEC -->|one criterion missing| OUT_LOW

    GATE{"<b>Investor gate 16c met?</b><br/>1–10 / €1,000–10,000 / days–weeks (or higher)"}
    GATE -->|no| OUT_RC4
    GATE -->|yes| CAP

    CAP{"<b>Investor safety cap</b><br/>Return only „≥ 10%“?"}
    CAP -->|yes| OUT_RC2
    CAP -->|no| FINAL

    FINAL{"<b>Step 17 final check</b><br/>Total loss = Yes<br/>and knowledge test passed?"}
    FINAL -->|no| OUT_RC1
    FINAL -->|yes| OUT_RC5

    OUT_LOW(["<b>Result: RC 1–4</b><br/>Neither score 19–25<br/>nor special pathway met"])
    OUT_RC4(["<b>Result: max. RC 4</b><br/>Score/special pathway OK,<br/>but 16c gate missing"])
    OUT_RC2(["<b>Result: max. RC 2</b><br/>Return only 10% selected"])
    OUT_RC1(["<b>Final RC 1</b><br/>No to total loss<br/>or knowledge test not passed"])
    OUT_RC5(["<b>Final RC 5 ✓</b><br/>Candidate for platform access<br/><i>Completion: page 4 — steps 22→23 (RC7) → 24</i>"])

    classDef step fill:#e8f4fc,stroke:#2b6cb0,stroke-width:2px
    classDef gate fill:#fff7e6,stroke:#c05621,stroke-width:2px
    classDef ok fill:#e6ffed,stroke:#276749,stroke-width:2px
    classDef block fill:#fff5f5,stroke:#c53030,stroke-width:2px
    class S15,S16,S17 step
    class PATH,SPEC,GATE,CAP,FINAL gate
    class OUT_RC5 ok
    class OUT_LOW,OUT_RC4,OUT_RC2,OUT_RC1 block
