flowchart TD
    START(["<b>FIN1 KYC – Zuordnung Risikoklasse 5</b><br/>Gilt für Schritte 15, 16 und 17 im Sign-Up<br/>(Landing → Get Started)<br/><i>Detailgrafiken: rc5-signup-flow-4seiten.pdf (Seiten 1–3 RK5, Seite 4 Schritte 22–24)</i>"])

  subgraph S15["<b>Schritt 15 – Finanzielle Informationen</b>"]
    S15A["Dropdowns:<br/>• Beschäftigungsstatus<br/>• Einkommensbereich<br/>• Liquide Mittel"]
    S15B["Beitrag zum Score: 0–12 Punkte"]
    S15C["<b>Nur Investor – Sonderpfad:</b><br/>Beschäftigung darf nicht „Arbeitslos“ sein"]
  end

  subgraph S16["<b>Schritt 16 – Anlageerfahrung</b>"]
    S16A["a) Aktien & b) ETFs → Score-Punkte"]
    S16B["<b>c) Zertifikate & Derivate – RC-5-Gate (rollenspezifisch)</b>"]
    S16C_INV["<b>Investor (Minimum):</b><br/>✓ 1–10 Transaktionen (oder mehr)<br/>✓ 1.000–10.000 € (oder mehr)<br/>✓ Tage bis Wochen (oder kürzer)"]
    S16C_TR["<b>Trader (streng):</b><br/>✓ 50+ Transaktionen<br/>✓ ≥ 10.000 € investiert<br/>✓ Minuten bis Stunden"]
    S16D["Ohne passendes Gate:<br/>berechnete RC 5 → <b>max. RC 4</b>"]
    S16E["d) Sonstige Vermögenswerte → Zusatzpunkte"]
  end

  subgraph S17["<b>Schritt 17 – Gewinnziel & Risikoprüfung</b>"]
    S17A["Rendite ≥ 50 % oder 100 % (10 % → Deckel)"]
    S17B["Totalverlustrisiko: Ja + Wissenstest bestanden"]
    S17C["Nein / Test fail → <b>finale RC 1</b>"]
  end

  START --> S15A
  S15A --> S15B
  S15A --> S15C
  S15B --> SCORE
  S15C --> SCORE
  S16A --> SCORE
  S16B --> S16C_INV
  S16B --> S16C_TR
  S16C_INV --> S16D
  S16C_TR --> S16D
  S16C_INV --> GATE_OK
  S16C_TR --> GATE_OK
  S16E --> SCORE
  S17A --> SCORE
  S17B --> S17_CHECK
  S17C --> OUT_RC1

  SCORE{"<b>Score 19–25 Punkte?</b><br/>Trader: einziger Weg<br/>Investor: oder Sonderpfad"}

  SCORE -->|"19–25"| GATE_OK
  SCORE -->|"Investor &lt; 19"| INV_SPEC
  SCORE -->|"Trader &lt; 19"| OUT_LOW
  INV_SPEC{"<b>Investor-Sonderpfad</b><br/>1. Nicht arbeitslos<br/>2. Investor-16c-Gate<br/>3. Rendite ≥ 50 %"}
  INV_SPEC -->|ja| GATE_OK
  INV_SPEC -->|nein| OUT_LOW

  GATE_OK{"<b>16c-Gate erfüllt?</b><br/>Investor: 1–10 / 1k–10k / Tage–Wochen+<br/>Trader: 50+ / ≥10k / Minuten–Stunden"}
  GATE_OK -->|nein| OUT_RC4
  GATE_OK -->|ja| ROLE_CAP

  ROLE_CAP{"<b>Sicherheitsdeckel</b><br/>Investor: nur Rendite 10 %<br/>Trader: konservative Derivate/Rendite"}
  ROLE_CAP -->|Deckel| OUT_RC2
  ROLE_CAP -->|ok| S17_CHECK

  S17_CHECK{"<b>Schritt 17 OK?</b><br/>Totalverlust Ja + Test bestanden"}
  S17_CHECK -->|nein| OUT_RC1
  S17_CHECK -->|ja| OUT_RC5

  OUT_LOW(["RC 1–4"])
  OUT_RC4(["max. RC 4 — 16c-Gate fehlt"])
  OUT_RC2(["max. RC 2 — Schutzdeckel"])
  OUT_RC1(["finale RC 1 — Step 17"])
  OUT_RC5(["finale RC 5 ✓<br/><i>Abschluss Seite 4: Schritte 22–24</i>"])

  classDef step fill:#e8f4fc,stroke:#2b6cb0,stroke-width:2px
  classDef gate fill:#fff7e6,stroke:#c05621,stroke-width:2px
  classDef ok fill:#e6ffed,stroke:#276749,stroke-width:2px
  classDef block fill:#fff5f5,stroke:#c53030,stroke-width:2px
  class S15,S16,S17 step
  class SCORE,INV_SPEC,GATE_OK,ROLE_CAP,S17_CHECK gate
  class OUT_RC5 ok
  class OUT_LOW,OUT_RC4,OUT_RC2,OUT_RC1 block
