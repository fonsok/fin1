flowchart TD
    TITLE(["<b>Page 3 – Trader</b><br/>When does a trader receive Risk Class 5?<br/>Steps 15, 16, 17"])

    NOTE["<b>Important:</b> Trader has <b>no special pathway</b>.<br/>RC 5 only via score 19–25 points<br/>+ all gates and no conservative pattern."]

    subgraph S15["<b>Step 15 – Financial information</b>"]
        S15A["Dropdowns:<br/>• Employment status (score only, no gate)<br/>• Income range (0–5 pts.)<br/>• Liquid assets (0–5 pts.)"]
        S15B["Income sources: Assets +2, Inheritance +1, Settlement +1"]
    end

    subgraph S16["<b>Step 16 – Investment experience</b>"]
        S16A["a) Stocks: count 0–3 pts., amount 0–4 pts."]
        S16B["b) ETFs: count 0–3 pts., amount 0–4 pts."]
        S16C["<b>c) Certificates & derivatives – MANDATORY GATE + high points</b>"]
        S16D["Trader derivative weighting:<br/>✓ Count <b>50+</b> → <b>+8 pts.</b> (investor only +3)<br/>✓ Amount <b>€10,000–100,000</b> → <b>+4 pts.</b><br/>✓ Amount <b>&gt; €100,000</b> → <b>+6 pts.</b><br/>✓ Holding <b>minutes–hours</b> → <b>+4 pts.</b>"]
        S16E["<b>Gate for RC 5</b> (in addition to points):<br/>50+ AND ≥ €10,000 AND minutes–hours<br/>Otherwise: max. RC 4 despite high score"]
        S16F["d) Real estate (+2) / Gold (+1)"]
    end

    subgraph S17["<b>Step 17 – Target return & risk check</b>"]
        S17A["Dropdown return:<br/>✓ <b>≥ 50%</b> (+3 pts.) or <b>≥ 100%</b> (+5 pts.)<br/>✗ <b>≥ 10%</b> → conservative pattern → max. RC 2"]
        S17B["Total loss risk: <b>Yes</b>"]
        S17C["Knowledge test: <b>all correct</b><br/>No/errors → <b>final RC 1</b>"]
    end

    TITLE --> NOTE
    NOTE --> S15A
    S15A --> SCORE
    S15B --> SCORE
    S16A --> SCORE
    S16B --> SCORE
    S16C --> S16D
    S16D --> S16E
    S16D --> SCORE
    S16F --> SCORE
    S17A --> SCORE
    S17B --> FINAL
    S17C --> OUT_RC1

    SCORE{"<b>Score pathway (only route)</b><br/>Sum of all points from steps 15–17<br/><b>19–25 points</b> required for RC 5"}

    SCORE -->|"19–25 points"| GATE
    SCORE -->|"below 19"| OUT_LOW

    GATE{"<b>Derivatives gate 16c met?</b><br/>50+ / ≥ €10,000 / minutes–hours"}
    GATE -->|no| OUT_RC4
    GATE -->|yes| CONS

    CONS{"<b>Trader safety cap</b><br/>Conservative pattern?<br/>✗ Derivatives: None, 1–10, 10–50<br/>✗ Amount: €0–1,000 or €1,000–10,000<br/>✗ Holding: months–years<br/>✗ Return: 10% only<br/><i>One match is enough → cap RC 2</i>"}

    CONS -->|yes, conservative| OUT_RC2
    CONS -->|no| FINAL

    FINAL{"<b>Step 17 final check</b><br/>Total loss = Yes<br/>and knowledge test passed?"}
    FINAL -->|no| OUT_RC1
    FINAL -->|yes| OUT_RC5

    EXAMPLE["<b>Minimal trader example (19 pts.)</b><br/>Step 15: low income/assets (0 pts.)<br/>Step 16: derivatives 50+ (+8), €10k–100k (+4), minutes (+4)<br/>Step 17: return ≥ 50% (+3)<br/>= 19 pts. → RC 5 (if all gates OK)"]

    OUT_LOW(["<b>Result: RC 1–4</b><br/>Score below 19 points"])
    OUT_RC4(["<b>Result: max. RC 4</b><br/>Score 19–25, but 16c gate missing<br/>(e.g. holding period „days–weeks“)"])
    OUT_RC2(["<b>Result: max. RC 2</b><br/>Conservative pattern in 16c or 17"])
    OUT_RC1(["<b>Final RC 1</b><br/>No to total loss<br/>or knowledge test not passed"])
    OUT_RC5(["<b>Final RC 5 ✓</b><br/>Candidate for platform access<br/><i>Completion: page 4 — steps 22→23 (RC7) → 24</i>"])

    OUT_RC5 -.-> EXAMPLE

    classDef step fill:#e8f4fc,stroke:#2b6cb0,stroke-width:2px
    classDef gate fill:#fff7e6,stroke:#c05621,stroke-width:2px
    classDef ok fill:#e6ffed,stroke:#276749,stroke-width:2px
    classDef block fill:#fff5f5,stroke:#c53030,stroke-width:2px
    classDef hint fill:#faf5ff,stroke:#6b46c1,stroke-width:1px
    class S15,S16,S17 step
    class SCORE,GATE,CONS,FINAL gate
    class OUT_RC5 ok
    class OUT_LOW,OUT_RC4,OUT_RC2,OUT_RC1 block
    class NOTE,EXAMPLE hint
